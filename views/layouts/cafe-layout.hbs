<!DOCTYPE html>
<html lang="ko">

<head>
  <meta charset="UTF-8">
  <title>Cafe</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/partials/cafe-header.css">
  <link rel="stylesheet" href="/css/partials/cafe-sidebar.css">
  <link rel="stylesheet" href="/css/pages/cafe-home.css">
  <link rel="stylesheet" href="/css/pages/cafe-post-create.css">
  <link rel="stylesheet" href="/css/pages/cafe-post-detail.css">
  <link rel="stylesheet" href="/css/pages/cafe-join.css">
  <script src="/js/api.js"></script>
  <style>
    .container {
      display: flex;
      max-width: 1080px;      /* 전체 너비 */
      margin: 0 auto;      /* 가운데 정렬 */
      gap: 30px;      /* 사이드바와 본문 사이 간격 */
      padding: 0;
    }

    .main-content {
      flex: 1;
      width: 1080px;
    }
  </style>
</head>

<body>

  {{> cafe-header}}

  <div class="container">
    
    {{#if showSidebar}}
      {{> cafe-sidebar }}
    {{/if}}

    <main class="main-content">
      {{{body}}}
    </main>

  </div>
</body>

</html>