<aside id="sidebar_right" class="sidebar-right">
    <div class="login-box">
        {{#if user}}
        <div class="user-info">
            <div class="avatar-wrap">
                <img src="{{user.profile_img}}" alt="프로필" class="avatar-img"
                    onerror="this.src='/images/avatar-default.jpg'">
                <button class="setting-btn" aria-label="설정">⚙️</button>
            </div>
            <div class="user-details">
                <div class="user-name">
                    <strong>{{user.nickname}}</strong>님
                </div>
            </div>
            <button id="logout-btn" class="logout-btn">로그아웃</button>
        </div>
        <a href="/create" class="create-cafe-btn">카페 만들기</a>
        {{else}}
        <a href="/login" class="create-cafe-btn">로그인</a>
        <div class="signup-section">
            <p class="signup-guide">계정이 없으신가요?</p>
            <button type="button" class="btn-cancel signup-btn" onclick="location.href='/signup'">새 계정 만들기</button>
        </div>
        {{/if}}
    </div>

    <div class="notice-box">
        <h3>공지사항</h3>
        <ul>
            <li>안전한 중고거래 가이드</li>
            <li>카페 서비스 점검 안내</li>
        </ul>
    </div>
</aside>
<script src="/js/sidebar_right.js"></script>